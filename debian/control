Package: open-webui-docker
Architecture: all
Pre-Depends: ca-certificates, curl, gnupg2, jq
Depends: ${misc:Depends}, open-webui-common
Conflicts: docker.io, docker-compose, docker-compose-v2, docker-doc,
 podman-docker
Description: Install docker, amd and nvidia APT sources lists
 Install docker sources from https://docs.docker.com/engine/install/ubuntu/
 Install NVIDIA Container Toolkit from https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/latest/install-guide.html
 Install AMD Container Toolkit from https://instinct.docs.amd.com/projects/container-toolkit/en/latest/container-runtime/quick-start-guide.html

Package: open-webui-docker-nvidia-source
Architecture: all
Depends: ${misc:Depends}, open-webui-docker
Description: Install NVIDIA APT extensions sources
 This package adds the repositories required for hardware-specific packages. It must be installed BEFORE the hardware-specific packages.
 Install NVIDIA Container Toolkit from https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/latest/install-guide.html.

