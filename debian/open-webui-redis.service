[Unit]
Description=Redis Docker Container
# Only start after Docker is ready
After=docker.service
Requires=docker.service
# Wait for network to be available
After=network-online.target

[Service]
Type=simple

# Environment files
EnvironmentFile=/etc/open-webui/open-webui-redis.conf
EnvironmentFile=/etc/default/open-webui
EnvironmentFile=-/etc/open-webui/open-webui-local.conf
EnvironmentFile=-/run/open-webui/open-webui-redis.conf

# Remove any existing container with this name before starting
ExecStartPre=-/usr/bin/docker rm -f owebui_redis
# Check if Docker image is available
ExecStartPre=/usr/lib/open-webui-tools/owebui_redis_env_cond \
    /etc/open-webui/open-webui-redis.conf \
    /etc/default/open-webui \
    /etc/open-webui/open-webui-local.conf \
    /run/open-webui/open-webui-redis.conf
# Generate dynamic environment file
ExecStartPre=-/usr/bin/mkdir -p /run/open-webui
ExecStartPre=/usr/lib/open-webui-tools/owebui_redis_env_pre \
    /etc/open-webui/open-webui-redis.conf \
    /etc/default/open-webui \
    /etc/open-webui/open-webui-local.conf \
    /run/open-webui/open-webui-redis.conf

# Post process
ExecStartPost=/usr/lib/open-webui-tools/owebui_redis_env_post \
    /etc/open-webui/open-webui-redis.conf \
    /etc/default/open-webui \
    /etc/open-webui/open-webui-local.conf \
    /run/open-webui/open-webui-redis.conf
ExecStopPost=/usr/lib/open-webui-tools/owebui_redis_env_stop \
    /etc/open-webui/open-webui-redis.conf \
    /etc/default/open-webui \
    /etc/open-webui/open-webui-local.conf \
    /run/open-webui/open-webui-redis.conf
ExecStopPost=-/usr/bin/docker rm -f owebui_redis

# Start the container in the foreground (no -d flag)
ExecStart=/usr/bin/docker run \
  --name owebui_redis \
  --rm \
  $OWEBUI_DOCKER_OPTS \
  $PORTMAP_CMD $PORTMAP_ARG \
  -v ${OWEBUI_REDIS}:/data \
  $REDIS_ENV \
  ${REDIS_IMAGE}

# Gracefully stop the container
ExecStop=/usr/bin/docker stop -t 30 owebui_redis

# Timeout for start operation
TimeoutStartSec=60
# Timeout for stop operation
TimeoutStopSec=35

# Always restart on failure
Restart=always
RestartSec=45

[Install]
WantedBy=multi-user.target
