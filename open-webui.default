# Defaults for open-webui
OWEBUI_USER=owebui
OWEBUI_GROUP=owebui
OWEBUI_HOME=/var/lib/owebui
OWEBUI_APP=/var/lib/owebui/app
OWEBUI_OLLAMA=/var/lib/owebui/ollama
OWEBUI_CADDY=/var/lib/owebui/caddy
OWEBUI_POSTGRESQL=/var/lib/owebui/postgresql
OWEBUI_SHARE=/var/lib/owebui/share
OWEBUI_NAME="Open WebUI"
